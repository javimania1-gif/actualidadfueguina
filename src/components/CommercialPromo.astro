---
import { SITE } from '../data/site';

const { placement = 'general' } = Astro.props;
const message = encodeURIComponent(`Hola, vi el espacio publicitario de Actualidad Fueguina y quiero conocer las opciones disponibles.`);
---
<aside class="commercial-promo" aria-label="Espacio publicitario" data-commercial-promo data-placement={placement}>
  <div class="promo-copy">
    <span class="promo-label">Espacio publicitario</span>
    <strong>Tu marca puede estar acá</strong>
    <p>Llegá a lectores de Río Grande, Tolhuin, Ushuaia y toda Tierra del Fuego.</p>
  </div>
  <a class="promo-cta" href={`${SITE.commercial.whatsappUrl}?text=${message}`} target="_blank" rel="noopener noreferrer">
    Anunciá con nosotros
    <span aria-hidden="true">→</span>
  </a>
</aside>

<script>
  document.querySelectorAll('[data-commercial-promo] .promo-cta').forEach((link) => {
    link.addEventListener('click', () => {
      const promo = link.closest('[data-commercial-promo]');
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'commercial_cta_click',
        commercial_placement: promo?.getAttribute('data-placement') || 'general',
        contact_method: 'whatsapp'
      });
    });
  });
</script>

<style>
  .commercial-promo {
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    margin: 2.5rem 0;
    padding: clamp(1.4rem, 4vw, 2.2rem);
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.14);
    border-radius: var(--radius);
    color: white;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background:
      radial-gradient(circle at 88% 18%, rgba(242,106,33,.95), transparent 20rem),
      linear-gradient(120deg, #111 0%, #202020 58%, #5a210d 100%);
    box-shadow: var(--shadow);
  }
  .commercial-promo::after {
    content: 'AF';
    position: absolute;
    z-index: -1;
    right: 1rem;
    bottom: -3.5rem;
    color: rgba(255,255,255,.06);
    font-size: 11rem;
    line-height: 1;
    font-weight: 950;
    letter-spacing: -.12em;
  }
  .promo-copy { max-width: 690px; }
  .promo-label {
    display: inline-flex;
    margin-bottom: .65rem;
    padding: .28rem .55rem;
    border: 1px solid rgba(255,255,255,.28);
    border-radius: 999px;
    color: rgba(255,255,255,.82);
    font-size: .7rem;
    font-weight: 850;
    letter-spacing: .11em;
    text-transform: uppercase;
  }
  .promo-copy strong { display: block; font-size: clamp(1.7rem, 4vw, 3rem); line-height: 1; letter-spacing: -.055em; }
  .promo-copy p { margin: .65rem 0 0; color: rgba(255,255,255,.78); }
  .promo-cta {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: .65rem;
    padding: .9rem 1.15rem;
    border-radius: 999px;
    background: white;
    color: #171717;
    font-weight: 900;
    text-decoration: none;
    box-shadow: 0 10px 30px rgba(0,0,0,.2);
  }
  .promo-cta:hover { color: var(--brand-dark); transform: translateY(-2px); }
  @media (max-width: 700px) {
    .commercial-promo { align-items: flex-start; flex-direction: column; }
    .promo-cta { width: 100%; justify-content: center; }
    .commercial-promo::after { font-size: 8rem; }
  }
</style>
