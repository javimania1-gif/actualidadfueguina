const gtmId = 'GTM-KDSH57P2'; // Hardcoded for Tag Manager
---

<!-- Google Tag Manager - Consent Mode Base -->
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  
  // Default consent mode
  gtag('consent', 'default', {
    'analytics_storage': 'denied',
    'ad_storage': 'denied',
    'ad_user_data': 'denied',
    'ad_personalization': 'denied',
    'wait_for_update': 500
  });

  // Load saved consent from localStorage if exists
  try {
    const savedConsent = localStorage.getItem('af_consent');
    if (savedConsent) {
      gtag('consent', 'update', JSON.parse(savedConsent));
    }
  } catch(e) {}
</script>

{gtmId && (
  <!-- Google Tag Manager -->
  <script is:inline define:vars={{ gtmId }}>
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer',gtmId);
  </script>
)}
