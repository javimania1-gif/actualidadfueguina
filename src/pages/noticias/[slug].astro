---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const noticias = await getCollection('noticias');
  return noticias.map((nota) => ({
    params: { slug: nota.slug },
    props: { nota }
  }));
}

const { nota } = Astro.props;
const { Content } = await render(nota);
const fmt = new Intl.DateTimeFormat('es-AR', { dateStyle: 'long' });
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: nota.data.title,
  description: nota.data.description,
  datePublished: nota.data.date.toISOString(),
  dateModified: nota.data.date.toISOString(),
  author: { '@type': 'Organization', name: nota.data.author },
  publisher: { '@type': 'Organization', name: 'Actualidad Fueguina', logo: { '@type': 'ImageObject', url: new URL('/logo-af.png', Astro.site).toString() } },
  image: nota.data.image ? new URL(nota.data.image, Astro.site).toString() : new URL('/og-default.png', Astro.site).toString(),
  mainEntityOfPage: Astro.url.href
};
---
<BaseLayout title={nota.data.title} description={nota.data.description} image={nota.data.image || '/og-default.png'} canonical={Astro.url.href}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article class="article">
    <header class="article-header">
      <span class="eyebrow">{nota.data.category}</span>
      <h1>{nota.data.title}</h1>
      <p class="lead">{nota.data.description}</p>
      <div class="meta"><span>{fmt.format(nota.data.date)}</span>{nota.data.location && <span>{nota.data.location}</span>}<span>{nota.data.author}</span></div>
    </header>
    <figure class="article-cover">
      <img class="cover" src={nota.data.image || '/og-default.png'} alt={nota.data.imageAlt || nota.data.title} loading="eager" />
    </figure>
    <div class="article-body">
      <Content />
      {nota.data.tags?.length > 0 && (
        <div class="tags">
          {nota.data.tags.map((tag) => <a class="tag" href={`/etiquetas/${tag.toLowerCase().replaceAll(' ', '-')}/`}>{tag}</a>)}
        </div>
      )}
      
      <div class="share-section">
        <h3>Compartir esta noticia</h3>
        <div class="share-buttons">
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener noreferrer" class="btn-share fb" aria-label="Compartir en Facebook">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
            Facebook
          </a>
          <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(nota.data.title)}`} target="_blank" rel="noopener noreferrer" class="btn-share x" aria-label="Compartir en X (Twitter)">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Postear
          </a>
          <a href={`https://api.whatsapp.com/send?text=${encodeURIComponent(nota.data.title + ' - ' + Astro.url.href)}`} target="_blank" rel="noopener noreferrer" class="btn-share wa" aria-label="Compartir en WhatsApp">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <button class="btn-share ig" id="share-native" aria-label="Compartir enlace">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            Compartir
          </button>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  const shareBtn = document.getElementById('share-native');
  if (shareBtn) {
    shareBtn.addEventListener('click', async () => {
      if (navigator.share) {
        try {
          await navigator.share({
            title: document.title,
            url: window.location.href
          });
        } catch (err) {
          console.log('Error al compartir', err);
        }
      } else {
        navigator.clipboard.writeText(window.location.href);
        alert('Enlace copiado al portapapeles');
      }
    });
  }
</script>

<style>
  .share-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border, #e5e7eb);
  }
  .share-section h3 {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    font-weight: 600;
  }
  .share-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .btn-share {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    color: white;
    transition: transform 0.2s, opacity 0.2s;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }
  .btn-share:hover {
    transform: translateY(-2px);
    opacity: 0.9;
  }
  .btn-share.fb { background-color: #1877f2; }
  .btn-share.x { background-color: #000000; }
  .btn-share.wa { background-color: #25d366; }
  .btn-share.ig { 
    background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); 
  }
</style>
