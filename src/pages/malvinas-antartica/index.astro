---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const noticias = (await getCollection('noticias'))
  .filter(n => n.data.territory === 'Malvinas' || n.data.territory === 'Antártida')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = new Intl.DateTimeFormat('es-AR', { dateStyle: 'long' });
---
<BaseLayout
  title="Malvinas y Antártida"
  description="Cobertura de Actualidad Fueguina sobre las Islas Malvinas y la Antártida Argentina."
>
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h1 class="title-lg">Malvinas y Antártida</h1>
        <p class="lead">Soberanía, política exterior e identidad nacional.</p>
      </div>
      <div class="cat-tabs">
        <a href="/categorias/malvinas/" class="cat-tab">Islas Malvinas</a>
        <a href="/categorias/antartida/" class="cat-tab">Antártida Argentina</a>
      </div>
      <div class="grid">
        {noticias.length === 0 ? (
          <p class="lead" style="grid-column: 1 / -1; text-align: center; padding: 4rem 2rem; color: var(--color-text-muted); font-style: italic;">
            Por el momento no hay noticias publicadas en Malvinas y Antártida.
          </p>
        ) : (
          noticias.map((nota) => (
            <article class="card news-card">
              <a href={`/noticias/${nota.slug}/`}>
                <img class="cover" src={nota.data.image || '/logo-af.jpg'} alt={nota.data.imageAlt || nota.data.title} loading="lazy" />
                <div class="card-content">
                  <span class="eyebrow">{nota.data.category}</span>
                  <h2 class="title-md">{nota.data.title}</h2>
                  <p>{nota.data.description}</p>
                  <div class="meta"><span>{fmt.format(nota.data.date)}</span></div>
                </div>
              </a>
            </article>
          ))
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .cat-tabs {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .cat-tab {
    padding: 0.4rem 1rem;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 2rem;
    font-size: 0.875rem;
    text-decoration: none;
    color: var(--color-text, #111);
    transition: background 0.2s, color 0.2s;
  }
  .cat-tab:hover {
    background: var(--color-accent, #e63946);
    color: #fff;
    border-color: var(--color-accent, #e63946);
  }
</style>
