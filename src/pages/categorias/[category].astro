---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const slugify = (s) => s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

export async function getStaticPaths() {
  const slugifyPath = (s) => s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  const noticias = await getCollection('noticias');
  
  // Categorías base del menú que siempre deben estar generadas para evitar enlaces rotos (404)
  const baseCategories = ['Río Grande', 'Ushuaia', 'Tolhuin', 'Provincia', 'Malvinas'];
  const newsCategories = noticias.map((n) => n.data.category).filter(Boolean);
  const uniqueCategories = [...new Set([...baseCategories, ...newsCategories])];

  return uniqueCategories.map((category) => ({ params: { category: slugifyPath(category) }, props: { category } }));
}

const { category } = Astro.props;
const noticias = (await getCollection('noticias'))
  .filter((n) => slugify(n.data.category) === slugify(category))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const fmt = new Intl.DateTimeFormat('es-AR', { dateStyle: 'long' });
---
<BaseLayout title={category} description={`Noticias de ${category} en Actualidad Fueguina.`}>
  <section class="section">
    <div class="container">
      <div class="section-head"><h1 class="title-lg">{category}</h1><p class="lead">Cobertura de Actualidad Fueguina.</p></div>
      <div class="grid">
        {noticias.length === 0 ? (
          <p class="lead" style="grid-column: 1 / -1; text-align: center; padding: 4rem 2rem; color: var(--color-text-muted); font-style: italic;">
            Por el momento no hay noticias publicadas en la categoría "{category}".
          </p>
        ) : (
          noticias.map((nota) => (
            <article class="card news-card">
              <a href={`/noticias/${nota.slug}/`}>
                <img class="cover" src={nota.data.image || '/logo-af.jpg'} alt={nota.data.imageAlt || nota.data.title} loading="lazy" />
                <div class="card-content">
                  <span class="eyebrow">{nota.data.category}</span>
                  <h2 class="title-md">{nota.data.title}</h2>
                  <p>{nota.data.description}</p>
                  <div class="meta"><span>{fmt.format(nota.data.date)}</span></div>
                </div>
              </a>
            </article>
          ))
        )}
      </div>
    </div>
  </section>
</BaseLayout>
